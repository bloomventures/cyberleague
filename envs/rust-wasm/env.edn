{:env/slug "rust-wasm"
 :env/language-slug "rust"
 :env/enabled? true
 :env/runtime :runtime/wasm
 :env/run-cmd "cargo run"
 :env/build-cmd "cargo build --release --target wasm32-wasip1"
 :env/artifact-path "target/wasm32-wasip1/release/bot.wasm"
 :env/argv ["$ARTIFACT"]
 :env/note "Requires the wasm32-wasip1 target (`rustup target add wasm32-wasip1`)."
 :env/status nil}
