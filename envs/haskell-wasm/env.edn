{:env/slug "haskell-wasm"
 :env/language-slug "haskell"
 :env/enabled? true
 :env/runtime :runtime/wasm
 :env/run-cmd "wasmtime out/main.wasm"
 :env/build-cmd "mkdir -p out && wasm32-wasi-cabal build && cp $(wasm32-wasi-cabal list-bin your-directory-name) out/main.wasm"
 :env/artifact-path "out/main.wasm"
 :env/argv []
 :env/note "Artifact should be a .wasm file with support for wasip1."
 :env/status nil}
