{:env/slug "python-pyinstaller-static"
 :env/language-slug "python"
 :env/enabled? true
 :env/runtime :runtime/firecracker
 :env/run-cmd "./bot"
 :env/build-cmd "pyinstaller --onefile --strip bot.py"
 :env/artifact-path "dist/bot"
 :env/argv ["$ARTIFACT"]
 :env/note "Requires pyinstaller (`pip install pyinstaller`). Should produce a single statically-linked executable at dist/bot. Currently, untested whether it is truly static or not."
 :env/status "experimental"}
