{:env/slug "java-uberjar"
 :env/language-slug "java"
 :env/enabled? true
 :env/runtime :runtime/firecracker
 :env/run-cmd "java -jar out/Main.jar"
 :env/build-cmd "mkdir -p out && cp json.jar out/ && cd out && jar xf json.jar && cd .. && javac -cp json.jar -d out Game.java Main.java && jar cfe out/Main.jar Main -C out ."
 :env/artifact-path "out/Main.jar"
 :env/argv ["java" "-jar" "$ARTIFACT"]
 :env/note "Artifact should be a jar that contains all dependencies (aka. 'uberjar')"}