{:env/slug "python-pyinstaller-static"
 :env/language-slug "python"
 :env/enabled? true
 :env/runtime :runtime/firecracker
 :env/run-cmd "./bot"
 :env/build-cmd "pyinstaller --onefile --strip bot.py"
 :env/artifact-path "dist/bot"
 :env/argv []
 :env/note "Requires pyinstaller (`pip install pyinstaller`). Produces a single statically-linked executable at dist/bot."}
